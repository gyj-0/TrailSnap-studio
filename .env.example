# ============================================
# TrailSnap 环境变量配置模板
# 复制为 .env 后根据实际情况修改
# ============================================

# --------------------------------------------
# 数据库配置
# --------------------------------------------
POSTGRES_USER=trailsnap
POSTGRES_PASSWORD=trailsnap_secret
POSTGRES_DB=trailsnap
DATABASE_URL=postgresql+asyncpg://trailsnap:trailsnap_secret@localhost:5432/trailsnap

# --------------------------------------------
# Redis 配置
# --------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --------------------------------------------
# 后端服务配置
# --------------------------------------------
# 密钥（生产环境请修改为随机字符串）
SECRET_KEY=your-secret-key-change-in-production-min-32-chars-long

# 调试模式
debug=false

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 时区
TIMEZONE=Asia/Shanghai

# --------------------------------------------
# AI 服务配置
# --------------------------------------------
# AI 服务地址（Docker 内使用服务名，本地开发使用 localhost）
AI_SERVICE_URL=http://localhost:8001

# AI 运行设备: cpu, cuda, auto
AI_DEVICE=auto

# 模型存储路径
MODEL_PATH=./models

# OCR 语言: ch, en, ch_sim, ch_tra, etc.
OCR_LANGUAGE=ch

# --------------------------------------------
# 文件存储配置
# --------------------------------------------
# 上传文件存储路径
UPLOAD_DIR=./uploads

# 单文件最大大小 (MB)
MAX_UPLOAD_SIZE=50

# 允许的图片格式
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp,heic

# --------------------------------------------
# 前端配置
# --------------------------------------------
# API 基础地址
VITE_API_BASE_URL=http://localhost:8000

# AI 服务基础地址
VITE_AI_BASE_URL=http://localhost:8001

# 应用标题
VITE_APP_TITLE=TrailSnap

# --------------------------------------------
# 邮件服务配置（可选）
# --------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# --------------------------------------------
# 第三方登录配置（可选）
# --------------------------------------------
# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
