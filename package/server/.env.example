# TrailSnap Application Configuration
# Copy this file to .env and modify as needed

# Application
TRAILSNAP_DEBUG=false
TRAILSNAP_ENVIRONMENT=development

# Server
TRAILSNAP_HOST=0.0.0.0
TRAILSNAP_PORT=8000
TRAILSNAP_RELOAD=true
TRAILSNAP_WORKERS=1

# Database (PostgreSQL)
TRAILSNAP_DATABASE_HOST=localhost
TRAILSNAP_DATABASE_PORT=5432
TRAILSNAP_DATABASE_USER=trailsnap
TRAILSNAP_DATABASE_PASSWORD=your-secure-password
TRAILSNAP_DATABASE_NAME=trailsnap

# Security
TRAILSNAP_SECRET_KEY=your-super-secret-key-change-this-in-production
TRAILSNAP_ACCESS_TOKEN_EXPIRE_MINUTES=30
TRAILSNAP_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
TRAILSNAP_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# File Storage
TRAILSNAP_UPLOAD_DIR=uploads
TRAILSNAP_MAX_UPLOAD_SIZE=52428800

# Logging
TRAILSNAP_LOG_LEVEL=INFO
TRAILSNAP_LOG_DIR=logs

# Railway Data Sync
TRAILSNAP_RAILWAY_SYNC_INTERVAL_MINUTES=60
TRAILSNAP_RAILWAY_API_BASE_URL=https://api.example.com/railway

# OCR/YOLO
TRAILSNAP_YOLO_MODEL_PATH=models/yolo
TRAILSNAP_OCR_MODEL_PATH=models/ocr
