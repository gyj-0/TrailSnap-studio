# AI Service Environment Configuration

# 服务配置
AI_ENV=development
AI_DEBUG=false
AI_HOST=0.0.0.0
AI_PORT=8001

# 设备配置
# auto: 自动选择 (GPU 优先)
# gpu: 强制使用 GPU
# cpu: 强制使用 CPU
AI_DEVICE=auto
AI_GPU_ID=0

# OCR 配置
AI_OCR_LANG=ch
AI_OCR_USE_ANGLE_CLS=true
AI_OCR_USE_GPU=true

# 人脸识别配置
AI_FACE_DET_THRESHOLD=0.5
AI_FACE_RECOGNITION_THRESHOLD=0.6
AI_FACE_MODEL_NAME=buffalo_l

# 目标检测配置
AI_DETECTION_MODEL=yolov8n
AI_DETECTION_CONF=0.25
AI_DETECTION_IOU=0.45

# 票据识别配置
AI_TICKET_MIN_CONFIDENCE=0.7

# 资源管理配置
AI_MODEL_CACHE_SIZE=3
AI_MODEL_IDLE_TIMEOUT=300
AI_MAX_IMAGE_SIZE=10485760
AI_MAX_IMAGE_DIMENSION=4096

# 日志配置
AI_LOG_LEVEL=INFO
AI_LOG_DIR=./logs
